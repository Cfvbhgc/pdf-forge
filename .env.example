# =============================================================================
# PDF Forge — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#
#   cp .env.example .env
#
# All variables below have sensible defaults so the app can start without
# a .env file, but you should review them for production deployments.
# =============================================================================

# ---- Server ------------------------------------------------------------------
# Port the Express server listens on.
PORT=3003

# Node environment: "development" | "production" | "test"
NODE_ENV=development

# ---- Puppeteer / Chromium ----------------------------------------------------
# Path to Chromium binary. Leave empty to let Puppeteer use its bundled version.
# Inside Docker this is typically /usr/bin/chromium-browser or /usr/bin/google-chrome-stable.
CHROMIUM_PATH=

# Set to "true" when running inside Docker or as root (disables the Chromium sandbox).
PUPPETEER_NO_SANDBOX=false

# ---- PDF Defaults ------------------------------------------------------------
# Default page format passed to Puppeteer's page.pdf() call.
# Supported values: Letter, Legal, Tabloid, Ledger, A0–A6, etc.
PDF_FORMAT=A4

# Print background graphics (colors, images) in the generated PDF.
PDF_PRINT_BACKGROUND=true
